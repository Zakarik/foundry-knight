{{!--
    Partial mutualisé des aspects exceptionnels (PNJ/Bande/Créature).
    Entête principale dépliée par défaut (minus-square) ; détail mineur/majeur
    de chaque aspect replié par défaut via le partial jsToggle (plus-square).
--}}
<div class="aspectsexceptionnels">
    <h2 class="header js-toggler">
        <i class="far fa-minus-square extendButton" data-action="jsToggle"></i>
        {{localize "KNIGHT.ASPECTS.Exceptionnels"}}
    </h2>

    {{#each actor.translations.aspectexceptionnel as | key aspect|}}
    <div class="data">
        <h3 class="header js-toggler">
            {{~> knight.jsToggle}}
            {{getAspect aspect}}
        </h3>
        {{#if key.mineur}}
            <div class="line">
                <span class="description">{{{key.mineur}}}</span>
            </div>
        {{/if}}

        {{#if key.majeur}}
            <div class="line">
                <span class="description">{{{key.majeur}}}</span>
            </div>
        {{/if}}
    </div>
    {{/each}}
</div>

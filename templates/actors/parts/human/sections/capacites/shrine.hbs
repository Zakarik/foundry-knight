
<div class="shrine">
    <h3 class="header js-toggler">
        {{~> knight.jsToggle}}
        {{label}}

        {{#if ("armure" @root/systemData/wear)}}
            <div class="blockMultiline">
            {{#unless active.base}}
                <button
                    data-action="activateHuman"
                    data-type="capacites"
                    data-capacite="{{key}}"
                    data-special="personnel">
                    {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Personnel"}} : {{localize "KNIGHT.AUTRE.Activer"}}
                </button>

                <button
                    data-action="activateHuman"
                    data-type="capacites"
                    data-capacite="{{key}}"
                    data-special="distance">
                    {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Distance"}} : {{localize "KNIGHT.AUTRE.Activer"}}
                </button>

                {{#if energie.acces6tours}}
                    <button
                        data-action="activateHuman"
                        data-type="capacites"
                        data-capacite="{{key}}"
                        data-special="personnel6">
                        {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Personnel6Tours"}} : {{localize "KNIGHT.AUTRE.Activer"}}
                    </button>

                    <button
                        data-action="activateHuman"
                        data-type="capacites"
                        data-capacite="{{key}}"
                        data-special="distance6">
                        {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Distance6Tours"}} : {{localize "KNIGHT.AUTRE.Activer"}}
                    </button>
                {{/if}}
            {{else}}
                {{#if active.personnel}}
                    <button
                    data-action="activateHuman"
                    data-type="capacites"
                    data-capacite="{{key}}"
                    data-special="personnel">
                    {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Personnel"}} : {{localize "KNIGHT.AUTRE.Desactiver"}}
                    </button>
                {{/if}}

                {{#if active.distance}}
                <button
                    data-action="activateHuman"
                    data-type="capacites"
                    data-capacite="{{key}}"
                    data-special="distance">
                    {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Distance"}} : {{localize "KNIGHT.AUTRE.Desactiver"}}
                </button>
                {{/if}}

                {{#if active.personnel6}}
                <button
                    data-action="activateHuman"
                    data-type="capacites"
                    data-capacite="{{key}}"
                    data-special="personnel6">
                    {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Personnel6Tours"}} : {{localize "KNIGHT.AUTRE.Desactiver"}}
                </button>
                {{/if}}

                {{#if this.active.distance6}}
                <button
                    data-action="activateHuman"
                    data-type="capacites"
                    data-capacite="{{key}}"
                    data-special="distance6">
                    {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Distance6Tours"}} : {{localize "KNIGHT.AUTRE.Desactiver"}}
                </button>
                {{/if}}

                <button
                    data-action="activateHuman"
                    data-type="prolonger"
                    data-capacite="{{key}}"
                    data-special="{{#if active.personnel}}personnel{{/if}}{{#if active.distance}}distance{{/if}}{{#if active.personnel6}}personnel6{{/if}}{{#if active.distance6}}distance6{{/if}}">
                    {{localize "KNIGHT.AUTRE.Prolonger"}}
                </button>
            {{/unless}}
            </div>
        {{/if}}
    </h3>

    <span class="description" style="display:none">{{{this.description}}}</span>

    <div class="mainData" style="display:none">
        <div class="data">
            <h4>{{localize "KNIGHT.LATERAL.Energie"}}</h4>
            <div class="longspan">
                <span class="header">{{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Personnel"}}</span>
                <span class="score">{{this.energie.personnel}}</span>
            </div>
            <div class="longspan">
                <span class="header">{{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Distance"}}</span>
                <span class="score">{{this.energie.distance}}</span>
            </div>
            <div class="longspan {{#unless this.energie.acces6tours}}hidden{{/unless}}">
                <span class="header">{{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Personnel6Tours"}}</span>
                <span class="score">{{this.energie.personnel6tours}}</span>
            </div>
            <div class="longspan {{#unless this.energie.acces6tours}}hidden{{/unless}}">
                <span class="header">{{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.SHRINE.ENERGIE.Distance6Tours"}}</span>
                <span class="score">{{this.energie.distance6tours}}</span>
            </div>
        </div>

        <div class="data">
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.ACTIVATION.Label"}}</span>
                <span class="score">{{{getActivation this.activation}}}</span>
            </div>
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.DUREE.Label"}}</span>
                <span class="score">{{{this.duree}}}</span>
            </div>
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.PORTEE.Label"}}</span>
                <span class="score">{{{this.portee}}}</span>
           </div>
            <div class="longspan separation">
                <span class="header">{{localize "KNIGHT.BONUS.ChampDeForce"}}</span>
                <span class="score">{{this.champdeforce}}</span>
           </div>
            <div class="longspan">
                <span class="header">{{localize "KNIGHT.REQUIS.Force"}}</span>
                <span class="score">{{this.requis.force}}</span>
            </div>
            <div class="longspan">
                <span class="header">{{localize "KNIGHT.REQUIS.Chair"}}</span>
                <span class="score">{{this.requis.chair}}</span>
           </div>
        </div>
    </div>
</div>

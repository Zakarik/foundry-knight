
<div class="oriflamme">
    <h3 class="header js-toggler">
        {{~> knight.jsToggle}}
        {{label}}

        {{#if ("armure" @root/systemData/wear)}}
        <div class="blockMultiline">
            <button
                data-action="activateHuman"
                data-type="capacites"
                data-capacite="{{key}}"
                data-special="degats"
                >
                {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.ORIFLAMME.Label"}} : {{localize "KNIGHT.AUTRE.Degats"}}
            </button>

            <button
                data-action="activateHuman"
                data-type="capacites"
                data-capacite="{{key}}"
                data-special="violence"
                >
                {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.ORIFLAMME.Label"}} : {{localize "KNIGHT.AUTRE.Violence"}}
            </button>

            <button
                data-action="activateHuman"
                data-type="capacites"
                data-capacite="{{key}}"
                data-special="degats/violence"
                >
                {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.ORIFLAMME.Label"}} : {{localize "KNIGHT.AUTRE.Degats"}} + {{localize "KNIGHT.AUTRE.Violence"}}
            </button>
        </div>
        {{/if}}
    </h3>

    <span class="description" style="display:none">{{{this.description}}}</span>

    <div class="mainData" style="display:none">
        <div class="data">
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.LATERAL.Energie"}}</span>
                <span class="score">{{this.energie}}</span>
            </div>
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.ACTIVATION.Label"}}</span>
                <span class="score">{{getActivation this.activation}}</span>
            </div>
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.DUREE.Label"}}</span>
                <span class="score">{{this.duree}}</span>
            </div>
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.PORTEE.Label"}}</span>
                <span class="score">{{getPortee this.portee}}</span>
            </div>
        </div>

        <div class="data">
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.AUTRE.Degats"}}</span>
                <span class="score">{{this.degats.dice}}{{localize "KNIGHT.JETS.Des-short"}}6+{{this.degats.fixe}}</span>
            </div>
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.AUTRE.Violence"}}</span>
                <span class="score">{{this.violence.dice}}{{localize "KNIGHT.JETS.Des-short"}}6+{{this.violence.fixe}}</span>
            </div>
            <div class="effets">
            {{#each this.effets.liste as | key effet|}}
                {{~> systems/knight/templates/parts/effets.html type='oriflamme'}}
            {{/each}}
            </div>
        </div>
    </div>
</div>

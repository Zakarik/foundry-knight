
<div class="ascension">
    <h3 class="header js-toggler">
        {{~> knight.jsToggle}}
        {{label}}

        {{#unless this.permanent}}
        {{#if ("armure" @root/systemData/wear)}}
        <div class="blockMultiline">
            <label class="energie">
                {{log data}}
                <input type="number"  data-dtype="Number"name="system.equipements.armure.capacites.ascension.energie"
                value="{{ifThen (lt data.ascension.energie energie.min) energie.min data.ascension.energie}}"
                min="{{energie.min}}" max="{{energie.max}}" />
                <span>{{localize "KNIGHT.AUTRE.PointEnergie-short"}}</span>
            </label>

            <button
                data-action="activateHuman"
                data-type="capacites"
                data-capacite="{{key}}">
                {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.ASCENSION.Label"}} : {{localizeactivate active}}
            </button>
        </div>
        {{else}}
            {{#unless ("ascension" @root/systemData/wear)}}
                {{#if this.sansarmure.acces}}
                <div class="blockMultiline"
                    <label class="energie">
                        <input type="number"  data-dtype="Number"name="system.equipements.armure.capacites.ascension.energie"
                        value="{{ifThen (lt data.ascension.energie energie.min) energie.min data.ascension.energie}}"
                        min="{{energie.min}}" max="{{energie.max}}" />
                        <span>{{localize "KNIGHT.AUTRE.PointEnergie-short"}}</span>
                    </label>

                    <button
                        data-action="activateHuman"
                        data-type="capacites"
                        data-capacite="{{key}}">
                        {{localize "KNIGHT.ITEMS.ARMURE.CAPACITES.ASCENSION.Label"}} : {{localizeactivate active}}
                    </button>
                </div>
                {{/if}}
            {{/unless}}
        {{/if}}
        {{/unless}}
    </h3>

    <span class="description" style="display:none">{{{this.description}}}</span>

    <div class="mainData" style="display:none">
        <div class="data">
            <div class="longspan">
                <span class="header">{{localize "KNIGHT.LATERAL.Energie"}}</span>
                <span class="score">
                    {{{this.energie.min}}}
                    -
                    {{{this.energie.max}}}
                </span>
            </div>
            <div class="longspan">
                <span class="header">{{localize "KNIGHT.AUTRE.GainImpregnation"}}</span>
                <span class="score">{{{this.impregnation}}}</span>
            </div>
        </div>

        <div class="data">
            <div class="shortspan">
                <span class="header">{{localize "KNIGHT.ACTIVATION.Label"}}</span>
                <span class="score">{{{getActivation this.activation}}}</span>
            </div>
            <div class="shortspan multiligne">
                <span class="header">{{localize "KNIGHT.DUREE.Label"}}</span>
                <span class="score">{{{this.duree}}}</span>
            </div>
        </div>
    </div>
</div>
